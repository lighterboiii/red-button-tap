# Полный URL бэкенда, без слэша в конце. В dev можно не задавать — будет http://localhost:<порт>.
# Прод / Vercel: обязательно, например https://buttoff-api.up.railway.app
# VITE_API_URL=

# Порт локального бэка (совпадает с PORT в backend/.env). По умолчанию 3001.
# VITE_API_PORT=3001

# Тесты: без дневного лимита и кулдауна (перезапусти dev-сервер после изменения)
# VITE_UNLIMITED_TAPS=true
